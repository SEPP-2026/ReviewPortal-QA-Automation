{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "noEmit": true
  },
  "include": [
    "config/**/*.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ]
}
